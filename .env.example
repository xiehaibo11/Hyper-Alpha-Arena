# Hyper Alpha Arena - Environment Configuration Template
# Copy this file to .env and fill in your values

# =================================================================
# Hyperliquid Trading Configuration (REQUIRED for real trading)
# =================================================================

# Encryption key for private key storage
# HYPERLIQUID_ENCRYPTION_KEY is automatically generated and persisted by Docker

# Hyperliquid defaults (optional, can be configured per account in UI)
HYPERLIQUID_MAX_LEVERAGE=10
HYPERLIQUID_MIN_ORDER_VALUE=10.0
HYPERLIQUID_MAX_POSITION_VALUE_PER_ORDER=1000.0

# =================================================================
# Database Configuration (Auto-configured in Docker)
# =================================================================
# These are automatically set by docker-compose.yml
# DATABASE_URL=postgresql://alpha_user:alpha_pass@postgres:5432/alpha_arena
# SNAPSHOT_DATABASE_URL=postgresql://alpha_user:alpha_pass@postgres:5432/alpha_snapshots

# =================================================================
# Optional: Custom AI Model Configuration
# =================================================================
# If you want to set default API keys (can also be configured per account in UI)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key

# =================================================================
# Optional: Upload Storage (Aliyun OSS + CDN)
# =================================================================
# local = keep uploads on app disk; oss = store uploads in Aliyun OSS
UPLOAD_STORAGE_MODE=local
# Use an OSS/CDN domain that actually serves the bucket. Do not point this to
# the app SPA domain unless that CDN path is routed to OSS.
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_STORAGE_LOCAL_ROOT=/app/data/uploads

# Required when UPLOAD_STORAGE_MODE=oss
UPLOAD_STORAGE_OSS_BUCKET=your-bucket-name
UPLOAD_STORAGE_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
UPLOAD_STORAGE_OSS_REGION=cn-hangzhou
UPLOAD_STORAGE_OSS_ACCESS_KEY_ID=your-access-key-id
UPLOAD_STORAGE_OSS_ACCESS_KEY_SECRET=your-access-key-secret
UPLOAD_STORAGE_OSS_SECURITY_TOKEN=
UPLOAD_STORAGE_OSS_CACHE_CONTROL=public,max-age=2592000
UPLOAD_STORAGE_OSS_SSE=AES256

# Mirror all AI/chat messages to upload storage for durable large-message storage.
MESSAGE_ARCHIVE_ENABLED=true
MESSAGE_ARCHIVE_PREFIX=messages
MESSAGE_ARCHIVE_OSS_BUCKET=

# Archive high-volume market data to OSS before deleting local PostgreSQL rows.
MARKET_DATA_ARCHIVE_ENABLED=true
MARKET_DATA_ARCHIVE_PREFIX=market-data
MARKET_DATA_ARCHIVE_OSS_BUCKET=
MARKET_DATA_RETENTION_DEFAULT_DAYS=1
MARKET_DATA_KLINE_RETENTION_DAYS=45
MARKET_DATA_MAX_WATCHLIST_SYMBOLS=100
KLINE_PRIMARY_SYMBOLS=BTC,ETH,SOL,BNB
KLINE_NON_PRIMARY_BATCH_SIZE=20
BINANCE_MAX_WATCHLIST_SYMBOLS=200
BINANCE_REST_CALL_LIMIT_PER_MINUTE=300
BINANCE_PRIMARY_SYMBOLS=BTC,ETH,SOL,BNB
BINANCE_KLINE_WS_INTERVALS=1m,3m,5m,15m,30m,1h,2h,4h,6h,8h,12h,1d,3d,1w,1M
BINANCE_KLINE_WS_MAX_STREAMS_PER_CONNECTION=900
BINANCE_KLINE_WS_FLUSH_INTERVAL_SECONDS=30
BINANCE_REST_KLINE_BACKUP_ENABLED=false
BINANCE_REST_KLINE_INITIAL_BACKFILL_ENABLED=false
BINANCE_REST_KLINE_INITIAL_LIMIT=2
BINANCE_KLINE_ROTATION_BATCH_SIZE=20
BINANCE_OI_ROTATION_BATCH_SIZE=25
BINANCE_FUNDING_ROTATION_BATCH_SIZE=25
BINANCE_SENTIMENT_ROTATION_BATCH_SIZE=20
BINANCE_ORDERBOOK_ROTATION_BATCH_SIZE=10
MARKET_DATA_ARCHIVE_BATCH_SIZE=10000
MARKET_DATA_ARCHIVE_MAX_BATCHES_PER_TABLE=50
MARKET_DATA_ARCHIVE_REQUIRE_SUCCESS=true
MARKET_DATA_ARCHIVE_OSS_CACHE_CONTROL=private,max-age=31536000

# Optional Aliyun credentials for CDN/API automation
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_CLOUD_SECURITY_TOKEN=

# =================================================================
# Optional: Hyper Insight Integration
# =================================================================
# Login-based Hyper Insight integration uses the same Casdoor account session
# that is already synced from Hyper Alpha Arena after the user signs in.
# Only the base URL is needed here unless the deployment wants to override it.
HYPER_INSIGHT_API_BASE_URL=https://hyper.akooi.com

# Event-contract product / white-label (frontend, Vite — must be prefixed VITE_)
VITE_PRODUCT_MODE=event_contract   # or 'full' for internal dev
VITE_SITE_NAME=Hyper Alpha Arena
VITE_SITE_URL=/
VITE_SITE_LOGO=/static/logo_app.png
